APP_NAME=justice-risk-platform
APP_ENV=dev
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# 数据库
DATABASE_URL=sqlite:///./justice_risk.db
# 生产推荐：postgresql+psycopg://postgres:postgres@localhost:5432/justice_risk

# Embedding
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=384

# LLM
LLM_PROVIDER=echo
LLM_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_TIMEOUT_SECONDS=45

# 法律知识库检索
KNOWLEDGE_TOP_K=5
KNOWLEDGE_SEMANTIC_WEIGHT=0.65
KNOWLEDGE_KEYWORD_WEIGHT=0.35

# 第二阶段预留
RISK_WEIGHT_CASE_COUNT=0.30
RISK_WEIGHT_TOTAL_AMOUNT=0.25
RISK_WEIGHT_PEOPLE_COUNT=0.20
RISK_WEIGHT_TREND=0.15
RISK_WEIGHT_REPEAT_DEFENDANT=0.10

RISK_RED_THRESHOLD=80
RISK_ORANGE_THRESHOLD=60
RISK_YELLOW_THRESHOLD=40
